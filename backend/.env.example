# Django Secret Key (Generate a new one for production)
SECRET_KEY=django-insecure-replace-this-with-a-real-secure-key

# Debug Mode (Set to False in production)
DEBUG=True

# Allowed Hosts (Comma separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (Default: SQLite)
# For PostgreSQL: DATABASE_URL=postgres://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Redis Configuration (For production WebSockets)
# USE_REDIS=True
# REDIS_URL=redis://localhost:6379/1

# Voting Salt (Critical: Changing this will invalidate old voter hashes)
VOTE_SALT=production-secret-voting-salt-2026

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-me
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7
